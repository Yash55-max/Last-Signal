# Last Signal — Firebase Configuration
# Copy this file to .env.local and fill in your own Firebase project values.
# Never commit your .env.local file.
#
# How to get these values:
# 1. Go to https://console.firebase.google.com
# 2. Create a new project (or use an existing one)
# 3. Add a web app and copy the config object
# 4. Paste each value below

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Cloud Messaging VAPID key (for push notifications)
# Found in: Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
VITE_FIREBASE_VAPID_KEY=
